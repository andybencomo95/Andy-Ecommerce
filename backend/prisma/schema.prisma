// ============================================
// ESQUEMA DE BASE DE DATOS - PRISMA
// Andy Ecommerce - Tienda en línea
// ============================================
// Why? Un schema bien diseñado es fundamental para el rendimiento.
// - Índices: aceleran búsquedas frecuentes
// - Soft deletes: permiten recuperar datos eliminados
// - Relaciones bien definidas: integridad de datos
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// MODELO DE USUARIO
// Why? Necesitamos búsqueda por email frecuente
// + campos para verificación de email
// ============================================
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique // @unique crea índice automáticamente
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // Why?追踪更新时间
  
  // Verificación de email
  isEmailVerified    Boolean  @default(false)
  emailVerifyToken   String?  // Token para verificar email
  emailVerifyExpires DateTime? // Cuando expira el token
  emailVerifiedAt    DateTime? // Cuando se verificó
  
  // Soft delete - Why? Para mantener historial de órdenes
  deletedAt DateTime?
  
  // Relaciones
  orders    Order[]

  // Índices adicionales para búsquedas frecuentes
  @@index([email])
  @@index([deletedAt])
}

// ============================================
// MODELO DE PRODUCTO
// Why? Búsqueda por categoría y nombre es muy común en e-commerce
// ============================================
model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  image       String
  category    String
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Soft delete
  deletedAt DateTime?

  // Relaciones
  orderItems  OrderItem[]

  // Índices para búsquedas frecuentes
  @@index([category])           // Para filtrar por categoría
  @@index([name])               // Para búsqueda por nombre
  @@index([deletedAt])          // Para excluir productos eliminados
  @@index([price])              // Para排序 por precio
}

// ============================================
// MODELO DE PEDIDO
// Why? Queries por usuario, estado de pago y entrega son comunes
// ============================================
model Order {
  id              String   @id @default(uuid())
  userId          String
  shippingAddress String   // JSON almacenado como string - Why? Estructura variable
  paymentMethod   String
  paymentResult   String?  // JSON de resultado de pago
  totalPrice      Float
  isPaid          Boolean  @default(false)
  paidAt          DateTime?
  isDelivered     Boolean  @default(false)
  deliveredAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade) // Why? Cascade eliminaitems cuando se elimina orden
  orderItems OrderItem[]

  // Índices para queries comunes
  @@index([userId])           // Para ver pedidos de un usuario
  @@index([isPaid])           // Para filtrar pedidos pagados
  @@index([isDelivered])      // Para filtrar pedidos entregados
  @@index([createdAt])        // Para ordenar por fecha
}

// ============================================
// MODELO DE ÍTEM DE PEDIDO
// Why? Necesitamos buscar por producto frecuentemente
// ============================================
model OrderItem {
  id        String   @id @default(uuid())
  productId String
  orderId   String
  name      String
  quantity  Int
  price     Float
  image     String

  // Relaciones
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict) // Why? No eliminar producto si hay pedidos
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Índices
  @@index([productId]) // Para ver ventas de un producto
  @@index([orderId])  // Para ver items de una orden
}